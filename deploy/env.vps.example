# Copy this file to /var/www/surf-crm/app/.env on the VPS.
# Do not commit the real .env file.

# Frontend build config. Use the public CRM API URL exposed by Nginx.
VITE_CRM_DATA_SOURCE=google-sheets
VITE_GOOGLE_SHEETS_PROXY_URL=https://crm.example.com/api/crm
VITE_GOOGLE_SHEETS_SPREADSHEET_ID=
VITE_CRM_ALLOW_MOCK_FALLBACK=false
VITE_CRM_DEBUG_GATEWAY=false
VITE_CRM_AUTH_ENABLED=true
VITE_CRM_AUTH_API_URL=https://crm.example.com/api/auth

# Backend proxy config.
GOOGLE_SHEETS_SPREADSHEET_ID=1lEehF5FbtT8E1rL5CTQ3PkVPRARfvk9SskdfyhpLLDc
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nREPLACE_ME\n-----END PRIVATE KEY-----\n"

CRM_PROXY_PORT=8787
CRM_ALLOWED_ORIGIN=https://crm.example.com

# Auth config.
# Generate CRM_AUTH_PASSWORD_HASH with: npm run auth:hash -- "your-password"
# Generate CRM_SESSION_SECRET with: openssl rand -base64 48
CRM_AUTH_ENABLED=true
CRM_AUTH_USERNAME=admin
CRM_AUTH_PASSWORD_HASH=
CRM_SESSION_SECRET=
CRM_SESSION_TTL_SECONDS=28800
CRM_COOKIE_SECURE=true

# Sheet layout.
GOOGLE_SHEET_HEADER_ROW=3
GOOGLE_SHEET_READ_LAST_COLUMN=Z
GOOGLE_SHEET_TAB_PROSPECTS=Prospects
GOOGLE_SHEET_TAB_MESSAGES=Messages
GOOGLE_SHEET_TAB_RELANCES=Relances
GOOGLE_SHEET_TAB_OUTBOUND_POOL=OUTBOUND_POOL
GOOGLE_SHEET_TAB_LEAD_MAGNETS=Lead magnets
GOOGLE_SHEET_TAB_APPRENTISSAGES=Apprentissages
GOOGLE_SHEET_TAB_WEEKLY_REVIEWS=Bilans hebdomadaires
GOOGLE_SHEET_TAB_QUESTIONNAIRE=LINKEDIN_FILTER_RESPONSES
GOOGLE_SHEET_TAB_WAITLIST=LINKEDIN_MISSION_CONTROL_WAITLIST
GOOGLE_SHEET_TAB_FEEDBACK=LINKEDIN_MISSION_CONTROL_FEEDBACK
